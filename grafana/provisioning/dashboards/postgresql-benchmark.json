{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Overview",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "title": "Active Connections",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=~\"$database\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "Cache Hit Ratio",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "sum(pg_stat_database_blks_hit{datname=~\"$database\"}) / (sum(pg_stat_database_blks_hit{datname=~\"$database\"}) + sum(pg_stat_database_blks_read{datname=~\"$database\"})) * 100",
          "legendFormat": "Cache Hit %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "title": "Transactions Per Second (TPS)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=~\"$database\"}[1m]) + rate(pg_stat_database_xact_rollback{datname=~\"$database\"}[1m])",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisLabel": "TPS",
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "pointSize": 3,
            "showPoints": "auto",
            "spanNulls": false
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Query Performance",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false
    },
    {
      "title": "Avg Query Duration (pg_stat_statements)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "rate(pg_stat_statements_total_time_seconds{datname=~\"$database\"}[1m]) / rate(pg_stat_statements_calls{datname=~\"$database\"}[1m])",
          "legendFormat": "{{queryid}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "unit": "s"
        }
      }
    },
    {
      "title": "Locks & Deadlocks",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "expr": "pg_locks_count{datname=~\"$database\", mode=~\"$lock_mode\"}",
          "legendFormat": "{{mode}}",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_deadlocks{datname=~\"$database\"}[1m])",
          "legendFormat": "deadlocks/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "pgbench Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "collapsed": false
    },
    {
      "title": "Commit vs Rollback Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=~\"$database\"}[1m])",
          "legendFormat": "commits/sec",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=~\"$database\"}[1m])",
          "legendFormat": "rollbacks/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Tuples: Fetched vs Returned",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_tup_fetched{datname=~\"$database\"}[1m])",
          "legendFormat": "fetched",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_tup_returned{datname=~\"$database\"}[1m])",
          "legendFormat": "returned",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      }
    },
    {
      "title": "WAL & Checkpoints",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "collapsed": true
    },
    {
      "title": "WAL Records/Bytes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_wal_records{datname=~\"$database\"}[1m])",
          "legendFormat": "records/sec",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_wal_bytes{datname=~\"$database\"}[1m])",
          "legendFormat": "bytes/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line" }, "unit": "short" }
      }
    },
    {
      "title": "Checkpoints",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "rate(pg_stat_database_checkpoints_timed{datname=~\"$database\"}[5m])",
          "legendFormat": "timed",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_checkpoints_req{datname=~\"$database\"}[5m])",
          "legendFormat": "requested",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line" } }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["postgresql", "benchmark", "pgbench"],
  "templating": {
    "list": [
      {
        "name": "database",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(pg_stat_database_blks_hit, datname)",
        "refresh": 1,
        "regex": "",
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "lock_mode",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(pg_locks_count, mode)",
        "refresh": 1,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"] },
  "timezone": "browser",
  "title": "PostgreSQL Benchmark Dashboard",
  "uid": "pg-benchmark-v1",
  "version": 1,
  "weekStart": ""
}