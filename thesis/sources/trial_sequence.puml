@startuml
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Verdana
skinparam sequenceMessageAlign center
skinparam participantFontSize 11
skinparam noteFontSize 10
skinparam sequenceArrowFontSize 10

participant "Optuna\n(SMAC/TPE)" as opt #f0f4ff
participant "pg_manager" as agent #f0f4ff
participant "PostgreSQL 17" as pg #e8f5e9
participant "pgbench" as bench #fff8e1
participant "Prometheus" as prom #fce4ec

opt -> agent : предложить конфигурацию\n(study.ask())
agent -> agent : backup: performance.conf -> .bak

agent -> pg : записать performance.conf

alt параметр требует рестарта
    agent -> pg : docker compose restart postgres
else горячая перезагрузка
    agent -> pg : SELECT pg_reload_conf()
end

agent -> agent : пауза 5 с\n(прогрев буферного кеша)
agent -> bench : docker compose run pgbench\n(120 с, 20 клиентов)
bench -> pg : транзакции TPC-B / OLAP
bench --> agent : прогон завершён

agent -> agent : пауза 15 с\n(завершение скрапинга)
agent -> prom : GET /api/v1/query_range\n(срединная часть окна ±2.5%)
prom --> agent : TPS, задержка, cache_hit_ratio

opt <- agent : tell(значение метрики)

@enduml
