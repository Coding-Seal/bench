@startuml
!theme plain
skinparam backgroundColor white
skinparam defaultFontName Verdana
skinparam componentFontSize 11
skinparam packageFontSize 12
skinparam componentStyle rectangle

package "Optimization Engine (optimizer.py)" #f0f4ff {
  component "Optuna Study" as optuna
  component "SMAC Sampler" as smac
  component "TPE Sampler\n(fallback)" as tpe
  database "optuna_study.db\n(SQLite)" as studydb

  optuna --> smac : основной сэмплер
  optuna .> tpe : резервный
  optuna --> studydb : сохранение trials
}

package "PostgreSQL Server" #e8f5e9 {
  component "Agent\n(pg_manager.py)" as agent
  database "PostgreSQL 17" as db
  component "pg_stat_database" as pgstat
}

package "Metrics Store" #fce4ec {
  component "postgres-exporter" as exporter
  component "Prometheus" as prom
}

package "Load Generator" #fff8e1 {
  component "pgbench" as bench
}

optuna --> agent : применить конфигурацию
optuna --> prom : запросить метрики
agent --> db : записать performance.conf
bench --> db : нагрузка
pgstat --> exporter : экспорт статистики
exporter --> prom : скрапинг каждые 10 с

@enduml
